# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (used for map display, geocoding, and route optimization)
MAPBOX_TOKEN=

# Public site URL
PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
# EMAIL_FROM defaults to "Garage Sale Tracker <noreply@frulahomes.com>"
# (see nuxt.config.ts) — override to your own verified Resend domain.
EMAIL_FROM=
# Where /api/sale-reports sends user-flagged listings. Defaults to
# missap1214@gmail.com if unset; override to your own admin inbox.
ADMIN_EMAIL=

# Sentry (error tracking) — optional, leave blank to disable
NUXT_PUBLIC_SENTRY_DSN=

# hCaptcha (signup bot protection) — optional, leave blank to disable
NUXT_PUBLIC_HCAPTCHA_SITE_KEY=
